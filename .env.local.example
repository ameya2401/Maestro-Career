# ==============================
# Maestro Career local env setup
# ==============================

# App URL used in Supabase password-recovery redirectTo.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------
# Supabase (required)
# Source: Supabase Dashboard -> Project Settings -> API
# ------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ------------------------------
# Razorpay (optional, only for payment flow)
# ------------------------------
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# ------------------------------
# Auth runtime tuning (optional)
# ------------------------------
AUTH_OTP_TTL_SECONDS=300
AUTH_SESSION_TTL_SECONDS=2592000
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_DEBUG_OTP=false
AUTH_STRICT_ERRORS=true

# ------------------------------
# Legacy OTP provider settings
# Not used by current Supabase auth flow routes.
# Keep only if you intentionally use src/lib/otp-delivery.ts.
# ------------------------------
OTP_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ------------------------------
# Brevo for auth emails
# IMPORTANT: Do NOT add BREVO_* env vars here for auth routes.
# Configure Brevo as custom SMTP in Supabase Dashboard:
# Authentication -> SMTP Settings
# ------------------------------
